[Desktop Entry]
Encoding=UTF-8
Name=Zoom
Comment=Magnify the entire desktop
Comment[es]=Ampliar todo el escritorio
Comment[ca]=Amplia tot l'escriptori
Icon=/usr/share/accesswizard/dock/icons/windowzoom.png
Path=/usr/share/kwin/builtin-effects/zoom.json
Exec=/usr/share/accesswizard/dock/tools/loadEffect.sh /usr/share/kwin/builtin-effects/zoom.json add
Fname=/usr/share/accesswizard/dock/default/002_zoom.desktop
